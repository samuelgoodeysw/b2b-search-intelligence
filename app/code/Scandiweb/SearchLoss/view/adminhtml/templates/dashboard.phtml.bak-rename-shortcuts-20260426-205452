<script>
document.addEventListener('DOMContentLoaded', function () {
    var currentSortKey = 'revenue';
    var currentSortDirection = 'desc';

    function getMainRows() {
        return Array.prototype.slice.call(document.querySelectorAll('tr.searchloss-main-row'));
    }

    function getDetailRow(mainRow) {
        var detailId = mainRow.getAttribute('data-detail-id');
        return detailId ? document.getElementById(detailId) : null;
    }

    function getRowValue(row, key) {
        var value = row.getAttribute('data-' + key) || '';

        if (key === 'searches' || key === 'revenue' || key === 'priority' || key === 'confidence') {
            return Number(value || 0);
        }

        return String(value || '');
    }

    function updateIndicators(activeKey, direction) {
        document.querySelectorAll('.searchloss-sort-indicator').forEach(function (indicator) {
            indicator.textContent = '↕';
        });

        document.querySelectorAll('.searchloss-sort-button').forEach(function (button) {
            if (button.getAttribute('data-sort-key') === activeKey) {
                var indicator = button.querySelector('.searchloss-sort-indicator');
                if (indicator) {
                    indicator.textContent = direction === 'asc' ? '↑' : '↓';
                }
            }
        });
    }

    function sortRows(key, direction) {
        var table = document.querySelector('.searchloss-table');
        if (!table) {
            return;
        }

        var tbody = table.querySelector('tbody');
        var rows = getMainRows();

        currentSortKey = key;
        currentSortDirection = direction;

        rows.sort(function (a, b) {
            var valueA = getRowValue(a, key);
            var valueB = getRowValue(b, key);

            if (valueA < valueB) {
                return direction === 'asc' ? -1 : 1;
            }

            if (valueA > valueB) {
                return direction === 'asc' ? 1 : -1;
            }

            return 0;
        });

        rows.forEach(function (row) {
            var detailRow = getDetailRow(row);

            tbody.appendChild(row);

            if (detailRow) {
                tbody.appendChild(detailRow);
            }
        });

        updateIndicators(key, direction);
    }

    function populateIssueFilter() {
        var issueSelect = document.getElementById('searchloss-issue-filter');
        if (!issueSelect) {
            return;
        }

        var seen = {};

        getMainRows().forEach(function (row) {
            var value = String(row.getAttribute('data-issue') || '');
            var label = String(row.getAttribute('data-issue-label') || value);

            if (value && !seen[value]) {
                seen[value] = label;
            }
        });

        Object.keys(seen).sort(function (a, b) {
            return seen[a].localeCompare(seen[b]);
        }).forEach(function (value) {
            var option = document.createElement('option');
            option.value = value;
            option.textContent = seen[value];
            issueSelect.appendChild(option);
        });
    }

    function applyFilters() {
        var termInput = document.getElementById('searchloss-term-filter');
        var prioritySelect = document.getElementById('searchloss-priority-filter');
        var issueSelect = document.getElementById('searchloss-issue-filter');
        var countEl = document.getElementById('searchloss-filter-count');

        var termQuery = termInput ? String(termInput.value || '').toLowerCase().trim() : '';
        var priority = prioritySelect ? String(prioritySelect.value || 'all') : 'all';
        var issue = issueSelect ? String(issueSelect.value || 'all') : 'all';

        var visibleCount = 0;
        var totalCount = 0;

        getMainRows().forEach(function (row) {
            var detailRow = getDetailRow(row);

            var rowTerm = String(row.getAttribute('data-term') || '');
            var rowPriority = String(row.getAttribute('data-priority') || '');
            var rowIssue = String(row.getAttribute('data-issue') || '');

            var matchesTerm = !termQuery || rowTerm.indexOf(termQuery) !== -1;
            var matchesPriority = priority === 'all' || rowPriority === priority;
            var matchesIssue = issue === 'all' || rowIssue === issue;
            var shouldShow = matchesTerm && matchesPriority && matchesIssue;

            totalCount += 1;

            if (shouldShow) {
                visibleCount += 1;
                row.style.display = '';
            } else {
                row.style.display = 'none';

                if (detailRow) {
                    detailRow.style.display = 'none';
                }

                var detailsButton = row.querySelector('.searchloss-details-button');
                if (detailsButton) {
                    detailsButton.textContent = 'View';
                }
            }
        });

        if (countEl) {
            countEl.textContent = 'Showing ' + visibleCount + ' of ' + totalCount + ' terms';
        }
    }

    function resetFilters() {
        var termInput = document.getElementById('searchloss-term-filter');
        var prioritySelect = document.getElementById('searchloss-priority-filter');
        var issueSelect = document.getElementById('searchloss-issue-filter');
        var sortSelect = document.getElementById('searchloss-sort-select');

        if (termInput) {
            termInput.value = '';
        }

        if (prioritySelect) {
            prioritySelect.value = 'all';
        }

        if (issueSelect) {
            issueSelect.value = 'all';
        }

        if (sortSelect) {
            sortSelect.value = 'revenue:desc';
        }

        getMainRows().forEach(function (row) {
            var detailRow = getDetailRow(row);
            var detailsButton = row.querySelector('.searchloss-details-button');

            row.style.display = '';

            if (detailRow) {
                detailRow.style.display = 'none';
            }

            if (detailsButton) {
                detailsButton.textContent = 'View';
            }
        });

        sortRows('revenue', 'desc');
        applyFilters();
    }

    function csvEscape(value) {
        value = String(value == null ? '' : value);
        return '"' + value.replace(/"/g, '""') + '"';
    }

    function exportCsv() {
        var rows = [
            ['Term', 'Searches', 'Revenue at Risk', 'Priority', 'Issue Type', 'Confidence', 'Suggested Action']
        ];

        getMainRows().forEach(function (row) {
            if (row.style.display === 'none') {
                return;
            }

            var termEl = row.querySelector('.searchloss-term');
            var priorityEl = row.querySelector('.searchloss-pill');

            rows.push([
                termEl ? termEl.textContent.trim() : '',
                row.getAttribute('data-searches') || '',
                row.getAttribute('data-revenue') || '',
                priorityEl ? priorityEl.textContent.trim() : '',
                row.getAttribute('data-issue-label') || '',
                row.getAttribute('data-confidence-label') || '',
                row.getAttribute('data-suggested-action') || ''
            ]);
        });

        var csv = rows.map(function (row) {
            return row.map(csvEscape).join(',');
        }).join('\n');

        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var link = document.createElement('a');

        link.href = url;
        link.download = 'search-loss-opportunities.csv';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    }

    document.addEventListener('click', function (event) {
        var detailsButton = event.target.closest('.searchloss-details-button');

        if (detailsButton) {
            var target = detailsButton.getAttribute('data-searchloss-target');
            var row = target ? document.getElementById(target) : null;

            if (row) {
                var isVisible = row.style.display !== 'none' && row.style.display !== '';
                row.style.display = isVisible ? 'none' : 'table-row';
                detailsButton.textContent = isVisible ? 'View' : 'Hide';
            }

            return;
        }

        var sortButton = event.target.closest('.searchloss-sort-button');

        if (sortButton) {
            var key = sortButton.getAttribute('data-sort-key');
            var direction;

            if (currentSortKey === key) {
                direction = currentSortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                direction = key === 'term' || key === 'issue' ? 'asc' : 'desc';
            }

            var sortSelect = document.getElementById('searchloss-sort-select');
            if (sortSelect) {
                sortSelect.value = key + ':' + direction;
            }

            sortRows(key, direction);
            applyFilters();
        }
    });

    var termInput = document.getElementById('searchloss-term-filter');
    var prioritySelect = document.getElementById('searchloss-priority-filter');
    var issueSelect = document.getElementById('searchloss-issue-filter');
    var sortSelect = document.getElementById('searchloss-sort-select');
    var resetButton = document.getElementById('searchloss-reset-filters');
    var exportButton = document.getElementById('searchloss-export-csv');

    if (termInput) {
        termInput.addEventListener('input', applyFilters);
    }

    if (prioritySelect) {
        prioritySelect.addEventListener('change', applyFilters);
    }

    if (issueSelect) {
        issueSelect.addEventListener('change', applyFilters);
    }

    if (sortSelect) {
        sortSelect.addEventListener('change', function () {
            var parts = String(sortSelect.value || 'revenue:desc').split(':');
            sortRows(parts[0], parts[1]);
            applyFilters();
        });
    }

    if (resetButton) {
        resetButton.addEventListener('click', resetFilters);
    }

    if (exportButton) {
        exportButton.addEventListener('click', exportCsv);
    }

    populateIssueFilter();
    sortRows('revenue', 'desc');
    applyFilters();
});
</script>

