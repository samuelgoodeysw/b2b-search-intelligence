function b2bStatusClass(string $status): string
{
    $status = strtolower(trim($status));

    if (
        str_contains($status, 'no later matching') ||
        str_contains($status, 'not recorded') ||
        str_contains($status, 'zero results') ||
        str_contains($status, 'unresolved') ||
        str_contains($status, 'may not have completed')
    ) {
        return 'b2b-status-risk';
    }

    if (
        str_contains($status, 'matching cart') ||
        str_contains($status, 'matching order') ||
        str_contains($status, 'led to cart') ||
        str_contains($status, 'led to order')
    ) {
        return 'b2b-status-good';
    }

    if (str_contains($status, 'completed')) {
        return 'b2b-status-neutral';
    }

    return 'b2b-status-neutral';
}
