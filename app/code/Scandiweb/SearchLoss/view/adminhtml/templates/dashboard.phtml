    left: 0 !important;
    right: auto !important;
    transform: none !important;
    z-index: 950 !important;
}

.searchloss-kpi-panel-title h2 .searchloss-tooltip-bubble::after,
.searchloss-money-actions-title h2 .searchloss-tooltip-bubble::after,
.searchloss-section-header h2 .searchloss-tooltip-bubble::after {
    top: auto !important;
