/* Tooltip placement rules by context. */
.searchloss-card,
.searchloss-money-action,
.searchloss-review-action,
.searchloss-kpi-panel-title,
.searchloss-money-actions-title {
    overflow: visible;
}

.searchloss-card .searchloss-tooltip-label,
.searchloss-money-action .searchloss-tooltip-label,
.searchloss-review-action .searchloss-tooltip-label,
.searchloss-kpi-panel-title .searchloss-tooltip-label,
.searchloss-money-actions-title .searchloss-tooltip-label {
    position: relative;
    overflow: visible;
}

/* KPI cards and action cards: open upward so bubbles do not collide with lower rows. */
.searchloss-card .searchloss-tooltip-bubble,
.searchloss-money-action .searchloss-tooltip-bubble,
.searchloss-review-action .searchloss-tooltip-bubble {
    width: 240px !important;
    min-width: 0 !important;
    max-width: 240px !important;
    top: auto !important;
    bottom: calc(100% + 8px) !important;
    left: 0 !important;
    right: auto !important;
    transform: none !important;
    z-index: 900 !important;
}

.searchloss-card .searchloss-tooltip-bubble::after,
.searchloss-money-action .searchloss-tooltip-bubble::after,
.searchloss-review-action .searchloss-tooltip-bubble::after {
    top: 100% !important;
    bottom: auto !important;
    left: 18px !important;
    right: auto !important;
    transform: none !important;
    border-top-color: #0f172a !important;
    border-bottom-color: transparent !important;
}

/* Right-edge cards: align bubble to the right so it stays inside the panel. */
.searchloss-grid > .searchloss-card:nth-child(5n) .searchloss-tooltip-bubble,
.searchloss-grid > .searchloss-card:nth-child(5n-1) .searchloss-tooltip-bubble,
.searchloss-money-actions-grid > *:nth-child(5n) .searchloss-tooltip-bubble,
.searchloss-money-actions-grid > *:nth-child(5n-1) .searchloss-tooltip-bubble {
    left: auto !important;
    right: 0 !important;
}

.searchloss-grid > .searchloss-card:nth-child(5n) .searchloss-tooltip-bubble::after,
.searchloss-grid > .searchloss-card:nth-child(5n-1) .searchloss-tooltip-bubble::after,
.searchloss-money-actions-grid > *:nth-child(5n) .searchloss-tooltip-bubble::after,
.searchloss-money-actions-grid > *:nth-child(5n-1) .searchloss-tooltip-bubble::after {
    left: auto !important;
    right: 18px !important;
}

/* Section title tooltips: open downward so they do not overlap the previous panel. */
.searchloss-kpi-panel-title h2 .searchloss-tooltip-bubble,
.searchloss-money-actions-title h2 .searchloss-tooltip-bubble,
.searchloss-section-header h2 .searchloss-tooltip-bubble {
