/* Unified tooltip positioning. Use one consistent set of rules. */
.searchloss-tooltip-label {
    position: relative;
    overflow: visible;
}

.searchloss-tooltip-bubble {
    display: none;
    position: absolute;
    z-index: 950;
    width: 280px;
    min-width: 0;
    max-width: min(280px, calc(100vw - 32px));
    padding: 11px 13px;
    border: 1px solid #1e293b;
    border-radius: 10px;
    background: #0f172a;
    color: #f8fafc;
    box-shadow: 0 16px 34px rgba(15,23,42,.28);
    font-size: 12px;
    font-weight: 650;
    line-height: 1.45;
    text-transform: none;
    white-space: normal;
    word-break: normal;
    overflow-wrap: break-word;
    text-align: left;
    pointer-events: none;
}

.searchloss-tooltip-label:hover .searchloss-tooltip-bubble,
.searchloss-tooltip-icon:focus + .searchloss-tooltip-bubble {
    display: block;
}

/* Card/action tooltips: open above the icon, aligned to the right edge. */
.searchloss-card .searchloss-tooltip-bubble,
.searchloss-money-action .searchloss-tooltip-bubble,
.searchloss-review-action .searchloss-tooltip-bubble {
    top: auto;
    bottom: calc(100% + 10px);
    left: auto;
    right: 0;
    transform: none;
}

.searchloss-card .searchloss-tooltip-bubble::after,
.searchloss-money-action .searchloss-tooltip-bubble::after,
.searchloss-review-action .searchloss-tooltip-bubble::after {
    content: "";
    position: absolute;
    top: 100%;
    bottom: auto;
    left: auto;
    right: 18px;
    transform: none;
    border: 6px solid transparent;
    border-top-color: #0f172a;
    border-bottom-color: transparent;
}

/* Section/panel title tooltips: open to the right of the heading label. */
.searchloss-kpi-panel-title .searchloss-tooltip-bubble,
.searchloss-money-actions-title .searchloss-tooltip-bubble,
.searchloss-section-header .searchloss-tooltip-bubble {
    top: 50%;
    bottom: auto;
    left: calc(100% + 10px);
    right: auto;
    transform: translateY(-50%);
    width: 320px;
    max-width: min(320px, calc(100vw - 48px));
}

.searchloss-kpi-panel-title .searchloss-tooltip-bubble::after,
.searchloss-money-actions-title .searchloss-tooltip-bubble::after,
.searchloss-section-header .searchloss-tooltip-bubble::after {
    content: "";
    position: absolute;
    top: 50%;
    bottom: auto;
    left: -12px;
    right: auto;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-right-color: #0f172a;
    border-top-color: transparent;
    border-bottom-color: transparent;
}

/* Table/filter tooltips: open below the label. */
.searchloss-table th .searchloss-tooltip-bubble,
.searchloss-filters .searchloss-tooltip-bubble {
    top: calc(100% + 8px);
    bottom: auto;
    left: 0;
    right: auto;
    transform: none;
}

.searchloss-table th .searchloss-tooltip-bubble::after,
.searchloss-filters .searchloss-tooltip-bubble::after {
    content: "";
    position: absolute;
    top: auto;
    bottom: 100%;
    left: 14px;
    right: auto;
    transform: none;
    border: 6px solid transparent;
    border-top-color: transparent;
    border-bottom-color: #0f172a;
}

.searchloss-table th:nth-last-child(-n+4) .searchloss-tooltip-bubble {
    left: auto;
    right: 0;
}

.searchloss-table th:nth-last-child(-n+4) .searchloss-tooltip-bubble::after {
    left: auto;
    right: 14px;
}

/* Responsive fallback: section title tooltips drop below on narrower screens. */
@media (max-width: 1200px) {
    .searchloss-kpi-panel-title .searchloss-tooltip-bubble,
    .searchloss-money-actions-title .searchloss-tooltip-bubble,
    .searchloss-section-header .searchloss-tooltip-bubble {
        top: calc(100% + 8px);
        bottom: auto;
        left: 0;
        right: auto;
        transform: none;
        width: 300px;
        max-width: min(300px, calc(100vw - 48px));
    }

    .searchloss-kpi-panel-title .searchloss-tooltip-bubble::after,
    .searchloss-money-actions-title .searchloss-tooltip-bubble::after,
    .searchloss-section-header .searchloss-tooltip-bubble::after {
        top: auto;
        bottom: 100%;
        left: 18px;
        right: auto;
        transform: none;
        border-right-color: transparent;
        border-bottom-color: #0f172a;
    }
}

