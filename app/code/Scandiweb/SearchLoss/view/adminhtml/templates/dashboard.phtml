<script>
document.addEventListener('DOMContentLoaded', function () {
    var currentSortKey = 'revenue';
    var currentSortDirection = 'desc';
    var currentMoneyActionEffort = 'all';
    var currentMoneyActionEffortLabel = '';

    function closeAuditGuideOnOutsideClick() {
        document.addEventListener('click', function (event) {
            document.querySelectorAll('.searchloss-audit-guide[open]').forEach(function (guide) {
                if (!guide.contains(event.target)) {
                    guide.removeAttribute('open');
                }
            });
        });

        document.addEventListener('keydown', function (event) {
            if (event.key !== 'Escape') {
                return;
            }

            document.querySelectorAll('.searchloss-audit-guide[open]').forEach(function (guide) {
                guide.removeAttribute('open');
            });
        });
    }

    closeAuditGuideOnOutsideClick();

    function updateAuditConfigOpenState() {
        var hasOpenConfig = document.querySelector('.searchloss-audit-config[open]') !== null;
        document.body.classList.toggle('searchloss-config-panel-open', hasOpenConfig);
    }

    document.querySelectorAll('.searchloss-audit-config').forEach(function (configPanel) {
        configPanel.addEventListener('toggle', updateAuditConfigOpenState);
    });

    document.querySelectorAll('.searchloss-audit-config-close').forEach(function (button) {
        button.addEventListener('click', function () {
            var configPanel = button.closest('.searchloss-audit-config');
            if (configPanel) {
                configPanel.removeAttribute('open');
                updateAuditConfigOpenState();
            }
        });
    });

    updateAuditConfigOpenState();

    document.querySelectorAll('.searchloss-audit-config-form').forEach(function (form) {
        var initialSnapshot = new FormData(form);
        var initialValues = {};

        initialSnapshot.forEach(function (value, key) {
            initialValues[key] = String(value);
        });

        function updateDirtyState() {
            var currentSnapshot = new FormData(form);
            var isDirty = false;

            currentSnapshot.forEach(function (value, key) {
                if (String(value) !== String(initialValues[key] || '')) {
                    isDirty = true;
                }
            });

            form.classList.toggle('searchloss-audit-config-form--dirty', isDirty);
        }

        form.querySelectorAll('input, textarea, select').forEach(function (field) {
            field.addEventListener('input', updateDirtyState);
            field.addEventListener('change', updateDirtyState);
        });

        form.addEventListener('submit', function () {
            form.classList.remove('searchloss-audit-config-form--dirty');
        });
    });

    function getMainRows() {
        return Array.prototype.slice.call(document.querySelectorAll('tr.searchloss-main-row'));
    }

    function getDetailRow(mainRow) {
        var detailId = mainRow.getAttribute('data-detail-id');
        return detailId ? document.getElementById(detailId) : null;
    }

    function getRowValue(row, key) {
        var value = row.getAttribute('data-' + key) || '';

        if (key === 'searches' || key === 'revenue' || key === 'confidence') {
            return Number(value || 0);
        }

        return String(value || '');
    }

    function updateIndicators(activeKey, direction) {
        document.querySelectorAll('.searchloss-sort-indicator').forEach(function (indicator) {
            indicator.textContent = '↕';
        });

        document.querySelectorAll('.searchloss-sort-button').forEach(function (button) {
            if (button.getAttribute('data-sort-key') === activeKey) {
                var indicator = button.querySelector('.searchloss-sort-indicator');
                if (indicator) {
                    indicator.textContent = direction === 'asc' ? '↑' : '↓';
                }
            }
        });
    }

    function sortRows(key, direction) {
        var table = document.querySelector('.searchloss-table');
        if (!table) {
            return;
        }

        var tbody = table.querySelector('tbody');
        var rows = getMainRows();

        currentSortKey = key;
        currentSortDirection = direction;

        rows.sort(function (a, b) {
            var valueA = getRowValue(a, key);
            var valueB = getRowValue(b, key);

            if (valueA < valueB) {
                return direction === 'asc' ? -1 : 1;
            }

            if (valueA > valueB) {
                return direction === 'asc' ? 1 : -1;
            }

            return 0;
        });

        rows.forEach(function (row) {
            var detailRow = getDetailRow(row);

            tbody.appendChild(row);

            if (detailRow) {
                tbody.appendChild(detailRow);
            }
        });

        updateIndicators(key, direction);
    }

    function populateIssueFilter() {
        var issueSelect = document.getElementById('searchloss-issue-filter');
        if (!issueSelect) {
            return;
        }

        var seen = {};

        getMainRows().forEach(function (row) {
            var value = String(row.getAttribute('data-issue') || '');
            var label = String(row.getAttribute('data-issue-label') || value);

            if (value && !seen[value]) {
                seen[value] = label;
            }
        });

        Object.keys(seen).sort(function (a, b) {
            return seen[a].localeCompare(seen[b]);
        }).forEach(function (value) {
            var option = document.createElement('option');
            option.value = value;
            option.textContent = seen[value];
            issueSelect.appendChild(option);
        });
    }

    function applyFilters() {
        var termInput = document.getElementById('searchloss-term-filter');
        var issueSelect = document.getElementById('searchloss-issue-filter');
        var countEl = document.getElementById('searchloss-filter-count');

        var termQuery = termInput ? String(termInput.value || '').toLowerCase().trim() : '';
        var issue = issueSelect ? String(issueSelect.value || 'all') : 'all';
        var effort = currentMoneyActionEffort || 'all';

        var visibleCount = 0;
        var totalCount = 0;

        getMainRows().forEach(function (row) {
            var detailRow = getDetailRow(row);

            var rowTerm = String(row.getAttribute('data-term') || '');
            var rowIssue = String(row.getAttribute('data-issue') || '');
            var rowEffort = String(row.getAttribute('data-effort') || '');

            var matchesTerm = !termQuery || rowTerm.indexOf(termQuery) !== -1;
            var matchesIssue = issue === 'all' || rowIssue === issue;
            var matchesEffort = effort === 'all' || rowEffort === effort;
            var shouldShow = matchesTerm && matchesIssue && matchesEffort;

            totalCount += 1;

            if (shouldShow) {
                visibleCount += 1;
                row.style.display = '';
            } else {
                row.style.display = 'none';

                if (detailRow) {
                    detailRow.style.display = 'none';
                }

                row.classList.remove('searchloss-main-row--open');
            }
        });

        if (countEl) {
            countEl.textContent = 'Showing ' + visibleCount + ' of ' + totalCount + ' terms';
        }
    }

    function updateMoneyActionCards() {
        var wrapper = document.querySelector('.searchloss-money-actions');

        document.querySelectorAll('.searchloss-money-action').forEach(function (card) {
            var effort = String(card.getAttribute('data-money-effort') || 'all');
            card.classList.toggle('searchloss-money-action--active', currentMoneyActionEffort !== 'all' && effort === currentMoneyActionEffort);
        });

        if (wrapper) {
            wrapper.classList.toggle('searchloss-money-actions--filtered', currentMoneyActionEffort !== 'all');
        }

        var activeFilter = document.getElementById('searchloss-active-worktype-filter');

        if (activeFilter) {
            if (currentMoneyActionEffort === 'all') {
                activeFilter.classList.remove('is-visible');
                activeFilter.innerHTML = '';
            } else {
                var activeLabel = currentMoneyActionEffortLabel || currentMoneyActionEffort;

                activeFilter.classList.add('is-visible');
                activeFilter.innerHTML = 'Showing work type: ' + activeLabel + ' <button type="button" id="searchloss-clear-active-worktype-filter">Clear</button>';
            }
        }
    }

    function resetFilters() {
        var termInput = document.getElementById('searchloss-term-filter');
        var issueSelect = document.getElementById('searchloss-issue-filter');
        var sortSelect = document.getElementById('searchloss-sort-select');

        if (termInput) {
            termInput.value = '';
        }

        if (issueSelect) {
            issueSelect.value = 'all';
        }

        if (sortSelect) {
            sortSelect.value = 'revenue:desc';
        }

        currentMoneyActionEffort = 'all';
        currentMoneyActionEffortLabel = '';
        updateMoneyActionCards();

        getMainRows().forEach(function (row) {
            var detailRow = getDetailRow(row);

            row.style.display = '';
            row.classList.remove('searchloss-main-row--open');

            if (detailRow) {
                detailRow.style.display = 'none';
            }

        });

        sortRows('revenue', 'desc');
        applyFilters();
    }

    function csvEscape(value) {
        value = String(value == null ? '' : value);
        return '"' + value.replace(/"/g, '""') + '"';
    }

    function exportCsv() {
        var rows = [
            ['Term', 'Searches', 'Est. Demand Value', 'Issue Type', 'Fix Effort', 'Recommended Next Step']
        ];

        getMainRows().forEach(function (row) {
            if (row.style.display === 'none') {
                return;
            }

            var termEl = row.querySelector('.searchloss-term');

            rows.push([
                termEl ? termEl.textContent.trim() : '',
                row.getAttribute('data-searches') || '',
                row.getAttribute('data-revenue') || '',
                row.getAttribute('data-issue-label') || '',
                row.getAttribute('data-effort-label') || '',
                row.getAttribute('data-suggested-action') || ''
            ]);
        });

        var csv = rows.map(function (row) {
            return row.map(csvEscape).join(',');
        }).join('\n');

        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var link = document.createElement('a');

        link.href = url;
        link.download = 'search-loss-current-view.csv';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    }

    document.addEventListener('click', function (event) {
        var moneyActionCard = event.target.closest('.searchloss-money-action');

        if (moneyActionCard) {
            var selectedEffort = String(moneyActionCard.getAttribute('data-money-effort') || 'all');
            var selectedLabel = String(moneyActionCard.getAttribute('data-money-effort-label') || selectedEffort);

            if (currentMoneyActionEffort === selectedEffort) {
                currentMoneyActionEffort = 'all';
                currentMoneyActionEffortLabel = '';
            } else {
                currentMoneyActionEffort = selectedEffort;
                currentMoneyActionEffortLabel = selectedLabel;
            }

            updateMoneyActionCards();
            applyFilters();

            var tableSection = document.querySelector('.searchloss-failed-search-section');
            if (tableSection) {
                tableSection.setAttribute('open', 'open');
                tableSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            return;
        }

        var clearMoneyActionFilter = event.target.closest('#searchloss-clear-money-action-filter, #searchloss-clear-active-worktype-filter');

        if (clearMoneyActionFilter) {
            currentMoneyActionEffort = 'all';
            currentMoneyActionEffortLabel = '';
            updateMoneyActionCards();
            applyFilters();
            return;
        }

        var mainRow = event.target.closest('tr.searchloss-main-row');

        if (mainRow) {
            var detailRow = getDetailRow(mainRow);

            if (detailRow) {
                var isVisible = detailRow.style.display !== 'none' && detailRow.style.display !== '';
                detailRow.style.display = isVisible ? 'none' : 'table-row';
                mainRow.classList.toggle('searchloss-main-row--open', !isVisible);
            }

            return;
        }

        var sortButton = event.target.closest('.searchloss-sort-button');

        if (sortButton) {
            var key = sortButton.getAttribute('data-sort-key');
            var direction;

            if (currentSortKey === key) {
                direction = currentSortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                direction = key === 'term' || key === 'issue' ? 'asc' : 'desc';
            }

            var sortSelect = document.getElementById('searchloss-sort-select');
            if (sortSelect) {
                sortSelect.value = key + ':' + direction;
            }

            sortRows(key, direction);
            applyFilters();
        }
    });

    var termInput = document.getElementById('searchloss-term-filter');
    var issueSelect = document.getElementById('searchloss-issue-filter');
    var sortSelect = document.getElementById('searchloss-sort-select');
    var resetButton = document.getElementById('searchloss-reset-filters');
    var exportButton = document.getElementById('searchloss-export-csv');

    if (termInput) {
        termInput.addEventListener('input', applyFilters);
    }

    if (issueSelect) {
        issueSelect.addEventListener('change', applyFilters);
    }

    if (sortSelect) {
        sortSelect.addEventListener('change', function () {
            var parts = String(sortSelect.value || 'revenue:desc').split(':');
            sortRows(parts[0], parts[1]);
            applyFilters();
        });
    }

    if (resetButton) {
        resetButton.addEventListener('click', resetFilters);
    }

    if (exportButton) {
        exportButton.addEventListener('click', exportCsv);
    }

    populateIssueFilter();
    sortRows('revenue', 'desc');
    applyFilters();
});
</script>


<script>
(function () {
    var storageKey = 'searchloss_period_scroll_y';

    function restoreScrollPosition() {
        var savedY = sessionStorage.getItem(storageKey);

        if (savedY === null) {
            return;
        }

        sessionStorage.removeItem(storageKey);

        var y = parseInt(savedY, 10);

        if (!isNaN(y)) {
            window.requestAnimationFrame(function () {
                window.scrollTo(0, y);
            });
        }
    }

    function rememberScrollBeforePeriodChange() {
        var links = document.querySelectorAll('.searchloss-periods a');

        links.forEach(function (link) {
            link.addEventListener('click', function () {
                sessionStorage.setItem(storageKey, String(window.scrollY || window.pageYOffset || 0));
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
            rememberScrollBeforePeriodChange();
            restoreScrollPosition();
        });
    } else {
        rememberScrollBeforePeriodChange();
        restoreScrollPosition();
    }
})();
</script>

