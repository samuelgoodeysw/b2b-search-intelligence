<?php
/** @var \Scandiweb\SearchLoss\Block\Frontend\Ga4Tag $block */
$measurementId = $block->getMeasurementId();

if (!$block->isEnabled() || $measurementId === '') {
    return;
}
?>
<script async src="https://www.googletagmanager.com/gtag/js?id=<?= $block->escapeHtmlAttr($measurementId) ?>"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '<?= $block->escapeJs($measurementId) ?>');

(function () {
    try {
        var path = String(window.location.pathname || '');
        var params = new URLSearchParams(window.location.search || '');
        var searchTerm = params.get('q') || params.get('query') || params.get('search') || params.get('keyword');

        if (path.indexOf('/catalogsearch/result') !== -1 && searchTerm) {
            gtag('event', 'view_search_results', {
                search_term: searchTerm
            });
        }
    } catch (error) {
        // Search Loss GA4 validation tag should never block the storefront.
    }
})();
</script>
