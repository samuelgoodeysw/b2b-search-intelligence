<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="controller_action_predispatch_catalogsearch_result_index">
        <observer name="scandiweb_searchloss_log_search_event"
                  instance="Scandiweb\SearchLoss\Observer\LogSearchEvent"/>
    </event>
    <event name="controller_action_postdispatch_catalogsearch_result_index">
        <observer name="scandiweb_searchloss_update_search_event_results"
                  instance="Scandiweb\SearchLoss\Observer\UpdateSearchEventResults"/>
    </event>
</config>
